MONGO_URL="mongodb://localhost:27017"
DB_NAME="recommendation_system"
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173"
SEED_ON_STARTUP=true
# BUG-11 fix: set a strong secret key here — admin endpoint is DISABLED until this is set
ADMIN_API_KEY="change-me-before-production"
# directory where the trained XGBoost model is saved
MODEL_DIR="./models"

# ── Real Data Mode ─────────────────────────────────────────────────────────────
# Set USE_REAL_DATA=true to seed with real APIs + MovieLens instead of Faker
USE_REAL_DATA=false

# ── Auto-Retrain ───────────────────────────────────────────────────────────────
# Number of new real-user interactions before XGBoost is retrained in background
RETRAIN_THRESHOLD=100

# ── Free API Keys (register at the URLs below, all free, ~5 min total) ─────────

# TMDB — movies + TV shows: https://www.themoviedb.org/settings/api
TMDB_API_KEY="YOUR_TMDB_API_KEY_HERE"

# RAWG.io — games: https://rawg.io/apidocs
RAWG_API_KEY="YOUR_RAWG_API_KEY_HERE"

# NewsData.io — news articles: https://newsdata.io/register
NEWSDATA_API_KEY="YOUR_NEWSDATA_API_KEY_HERE"

# NewsAPI (newsapi.org) — second news source: https://newsapi.org/register
NEWSAPI_KEY="YOUR_NEWSAPI_KEY_HERE"

# Last.fm — music + podcasts: https://www.last.fm/api/account/create
LASTFM_API_KEY="YOUR_LASTFM_API_KEY_HERE"

# YouTube Data API v3 — videos: https://console.cloud.google.com → Enable YouTube Data API v3
YOUTUBE_API_KEY="YOUR_YOUTUBE_API_KEY_HERE"

# Spotify Web API — music albums: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID="YOUR_SPOTIFY_CLIENT_ID_HERE"
SPOTIFY_CLIENT_SECRET="YOUR_SPOTIFY_CLIENT_SECRET_HERE"

# Open Library (books) — NO API KEY NEEDED (works out of the box)
# Open Food Facts (products) — NO API KEY NEEDED (works out of the box)

# ── Free Dataset Config ──────────────────────────────────────────────────────
# Which MovieLens dataset to use: "1m" (fast, 1M ratings) or "25m" (rich, 25M ratings)
ML_DATASET_SIZE="1m"
# Load extra free datasets alongside MovieLens (Book-Crossings, Steam, Amazon)
LOAD_EXTRA_DATASETS=true
